function runTripleEngine() {
    const datetimeVal = document.getElementById('birthDatetime').value;
    if (!datetimeVal) { 
        alert("請選擇時空交會坐標！"); 
        return; 
    }

    // 1. 解析日期時間
    const date = new Date(datetimeVal);
    
    // 2. 驅動萬年曆組件
    const solar = Solar.fromYmdHms(
        date.getFullYear(), 
        date.getMonth() + 1, 
        date.getDate(), 
        date.getHours(), 
        date.getMinutes(), 
        0
    );
    const lunar = Lunar.fromSolar(solar);

    // 3. 打開隱藏的結果面板塊
    document.getElementById('resultArea').style.display = 'block';

    // 4. 依序執行三大核心演算模組 (確保順序與資料傳遞無誤)
    calculateBaziCore(lunar, date);
    const ziweiMain = calculateZiweiCore(date);
    calculateQimenAndReport(date, lunar, ziweiMain);

    // 5. 滑順滾動到結果頁面
    document.getElementById('resultArea').scrollIntoView({ behavior: 'smooth' });
}
